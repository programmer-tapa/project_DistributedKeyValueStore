# ==============================================================================
# DKV (Distributed Key-Value Store) Configuration
# ==============================================================================

# Address of the configuration metadata store (kvsrv)
# Use 'localhost:9000' from host machine, or 'kvsrv:9000' within the docker network.
DKV_CTRLED_ADDR=localhost:9000

# Host client port-forward mappings: translate internal container addresses to host localhost ports.
# These allow dkv-client running on the host machine to reach the docker containers directly.
MAP_kvraft-0:8000=localhost:8000
MAP_kvraft-1:8000=localhost:8001
MAP_kvraft-2:8000=localhost:8002
MAP_shardgrp2-0:8010=localhost:8010
MAP_shardgrp2-1:8010=localhost:8011
MAP_shardgrp2-2:8010=localhost:8012
